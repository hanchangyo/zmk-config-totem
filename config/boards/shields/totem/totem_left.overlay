#include "totem.dtsi"

#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>
#include <zephyr/dt-bindings/i2c/i2c.h>

&kscan0 {
    col-gpios
        = <&xiao_d 4 GPIO_ACTIVE_HIGH>
        , <&xiao_d 5 GPIO_ACTIVE_HIGH>
        , <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9 GPIO_ACTIVE_HIGH>
        , <&xiao_d 8 GPIO_ACTIVE_HIGH>
        ;
};

/*
 * The left half hosts the ATTiny I2C TrackPoint module.
 * Wiring (matches the standalone Arduino test project):
 *     SDA -> P1.00
 *     SCL -> P0.16
 *
 * i2c1 is used because i2c0's default pins (D4/D5) are already taken by
 * the key matrix columns on the left half. The XIAO BLE board DTS already
 * has i2c1 enabled as "nordic,nrf-twi", we just remap its pinctrl psels.
 */

&pinctrl {
    tp_i2c_default: tp_i2c_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 1, 0)>,
                    <NRF_PSEL(TWIM_SCL, 0, 16)>;
        };
    };

    tp_i2c_sleep: tp_i2c_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 1, 0)>,
                    <NRF_PSEL(TWIM_SCL, 0, 16)>;
            low-power-enable;
        };
    };
};

&i2c1 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;
    pinctrl-0 = <&tp_i2c_default>;
    pinctrl-1 = <&tp_i2c_sleep>;
    pinctrl-names = "default", "sleep";

    trackpoint: trackpoint@20 {
        compatible = "zmk,input-trackpoint";
        reg = <0x20>;
        status = "okay";

        /* Active poll = 8ms (125 Hz). The ATTiny updates at its own rate
         * and the driver dedupes by sequence number, so over-polling is
         * harmless but wastes energy. */
        poll-period-ms = <8>;
        idle-poll-period-ms = <125>;
        idle-timeout-ms = <1500>;

        /* Raw samples within +/- dead-zone are treated as no-motion and
         * used to self-calibrate the baseline; tune up if the pointer
         * still drifts while untouched. */
        dead-zone = <30>;

        /* Output divisor = 2^sensitivity-shift. Increase for slower,
         * finer cursor movement; decrease to make the stick feel faster. */
        sensitivity-shift = <2>;
    };
};

/ {
    trackpoint_listener: trackpoint_listener {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&trackpoint>;
    };
};
