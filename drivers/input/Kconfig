config INPUT_HANC_TRACKPOINT_I2C
    bool "hanc ATTiny-based I2C trackpoint"
    default y
    depends on DT_HAS_HANC_TRACKPOINT_I2C_ENABLED
    depends on INPUT
    select I2C
    help
      Enable the custom I2C trackpoint driver that polls an ATTiny
      co-processor at address 0x20 for dx/dy/button reports and emits
      Zephyr input events.

if INPUT_HANC_TRACKPOINT_I2C

config INPUT_HANC_TRACKPOINT_I2C_THREAD_STACK_SIZE
    int "Stack size for the trackpoint poll work queue"
    default 1024

config INPUT_HANC_TRACKPOINT_I2C_LOG_LEVEL
    int "Log level for hanc_trackpoint_i2c (0=off 1=ERR 2=WRN 3=INF 4=DBG)"
    range 0 4
    default 2

endif # INPUT_HANC_TRACKPOINT_I2C
